{
  "name": "dgmo",
  "version": "1.18.0",
  "description": "Render Diagrammo diagrams inline in Obsidian notes",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "gen:map-data": "node scripts/copy-map-data.mjs",
    "gen:examples": "node scripts/copy-example-note.mjs",
    "gen:styles": "node scripts/build-styles.mjs",
    "gen:templates": "node scripts/build-templates.mjs",
    "gen:assets": "node scripts/copy-map-data.mjs && node scripts/copy-example-note.mjs && node scripts/build-templates.mjs && node scripts/build-styles.mjs",
    "postinstall": "pnpm gen:assets",
    "build": "pnpm gen:assets && node esbuild.config.mjs",
    "dev": "pnpm gen:assets && node esbuild.config.mjs --watch",
    "test": "pnpm gen:assets && vitest run",
    "typecheck": "pnpm gen:assets && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check:deadcode": "knip",
    "check:duplication": "jscpd ./src",
    "check:all": "pnpm check:deadcode && pnpm check:duplication",
    "check:security": "pnpm audit --prod"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=7.28.0 <8"
    }
  },
  "dependencies": {
    "@diagrammo/dgmo": "^0.50.2"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@eslint/js": "^10.0.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@replit/codemirror-vim": "^6.3.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jscpd": "^4.0.9",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "obsidian": "^1.12.3",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.8",
    "wawoff2": "^2.0.1"
  }
}
