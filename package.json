{
  "name": "dgmo",
  "version": "1.5.11",
  "description": "Render Diagrammo diagrams inline in Obsidian notes",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check:security": "pnpm audit --prod"
  },
  "dependencies": {
    "@diagrammo/dgmo": "^0.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "obsidian": "^1.12.3",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "wawoff2": "^2.0.1"
  }
}
